<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.kinostream" name="Kino Stream Repository" version="1.3.2" provider-name="Kino Stream">
  <extension point="xbmc.addon.repository" name="Kino Stream Repository">
    <dir>
      <info compressed="false">https://nxt124.github.io/kinostream-repo/addons.xml</info>
      <checksum>https://nxt124.github.io/kinostream-repo/addons.xml.md5</checksum>
      <datadir zip="true">https://nxt124.github.io/kinostream-repo/zips/</datadir>
      <hashes>false</hashes>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="cs_CZ">Repozitář pro Kino Stream</summary>
    <summary lang="en_GB">Repository for Kino Stream</summary>
    <description lang="cs_CZ">Instalační a aktualizační repozitář pro addon Kino Stream.</description>
    <description lang="en_GB">Installation and update repository for the Kino Stream add-on.</description>
    <platform>all</platform>
    <license>GPL-3.0</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon>
<addon id="plugin.video.kinostream"
       name="Kino Stream"
       version="2.5.4"
       provider-name="Kino Stream">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="cs_CZ">Filmy a seriály z Webshare.cz </summary>
    <summary lang="en_GB">Movies and TV shows from Webshare.cz</summary>
    <description lang="cs_CZ">Kino Stream - Streamování filmů a seriálu z Webshare.cz</description>
    <description lang="en_GB">Kino Stream - Stream movies and TV shows from Webshare.cz. </description>
    <platform>all</platform>
    <license>GPL-3.0</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart_v253.png</fanart>
    </assets>
    <news>v2.5.1 - aktualizace verze pro GitHub repozitář</news>
  </extension>
</addon>
</addons>
